{
  "name": "@brick/base",
  "version": "0.1.0",
  "description": "Brick - A modular coding agent base. Snap extensions together like building blocks.",
  "bin": {
    "brick": "./dist/cli.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ansi-escapes": "^7.3.0",
    "boxen": "^8.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^13.0.0",
    "ink": "^7.0.3",
    "react": "^18.3.0",
    "semver": "^7.8.0",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "coding-agent",
    "modular",
    "ai",
    "mcp",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
